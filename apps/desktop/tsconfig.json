{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "types": ["vite/client"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "scripts/**/*.mjs"]
}
