{
  "extends": "@workspace/typescript-config/nodejs.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "scripts/**/*.mjs"]
}
