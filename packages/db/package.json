{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "description": "Database schema and utilities",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:create": "dotenv -e ../../.env -- tsx src/create-db.ts",
    "db:drop": "dotenv -e ../../.env -- tsx src/drop-db.ts",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:push:force": "dotenv -e ../../.env -- drizzle-kit push --force",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:empty": "dotenv -e ../../.env -- tsx src/empty.ts",
    "db:reset": "dotenv -e ../../.env -- tsx src/empty.ts --execute && dotenv -e ../../.env -- tsx src/seed.ts",
    "db:setup": "pnpm db:create && pnpm db:push:force",
    "clean": "rm -rf drizzle .turbo",
    "db:setup:seed": "pnpm db:setup && pnpm db:seed"
  },
  "keywords": [
    "database",
    "drizzle",
    "sqlite"
  ],
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@workspace/types": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "dotenv-expand": "^12.0.3",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0"
  }
}
