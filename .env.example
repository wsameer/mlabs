
# Default environment variables for local development
# Copy this to .env and customize as needed
# This file is committed to git and should NOT contain secrets

# Database (SQLite file path, relative to repo root)
DATABASE_URL=./data/mlabs.db

# API Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# CORS - Frontend dev server
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Frontend Configuration (for Vite proxy)
VITE_API_URL=http://localhost:3000
