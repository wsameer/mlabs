{
  "name": "mlabs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "dev:api": "pnpm --filter=api dev",
    "dev:web": "pnpm --filter=web dev",
    "build:api": "pnpm --filter=api build",
    "build:web": "pnpm --filter=web build",
    "start": "pnpm --filter=api start",
    "lint:fix": "turbo run lint:fix",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "clean:full": "turbo run clean && rm -rf node_modules .turbo",
    "db:setup": "pnpm --filter=@workspace/db db:setup",
    "db:generate": "pnpm --filter=@workspace/db db:generate",
    "db:push": "pnpm --filter=@workspace/db db:push",
    "db:studio": "pnpm --filter=@workspace/db db:studio",
    "db:seed": "pnpm --filter=@workspace/db db:seed",
    "db:empty": "pnpm --filter=@workspace/db db:empty",
    "db:reset": "pnpm --filter=@workspace/db db:reset",
    "db:docker:up": "docker compose up -d db",
    "db:docker:down": "docker compose stop db",
    "db:docker:restart": "docker compose restart db",
    "db:docker:logs": "docker compose logs -f db",
    "db:docker:status": "docker compose ps db",
    "db:docker:reset": "docker compose down -v && docker compose up -d db",
    "db:bootstrap": "pnpm db:setup",
    "db:bootstrap:seed": "pnpm db:setup:seed"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint-config-turbo": "^2.7.1",
    "eslint-plugin-turbo": "^2.5.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20.20.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.33.5",
      "sharp-ico": "^0.1.5"
    }
  }
}
